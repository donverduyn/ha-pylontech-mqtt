// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/python
{
  "name": "Python 3",
  // Matches .github/workflows/tests.yaml's actions/setup-python version and
  // requirements_dev.lock.txt's --python-version target — a devcontainer on
  // a different Python/HA combination than CI is exactly the drift that let
  // this repo declare HA 2024.11 as its minimum while never testing it.
  "image": "mcr.microsoft.com/devcontainers/python:3-3.14-trixie",
  "features": {
    "ghcr.io/devcontainers-extra/features/ripgrep:1": {
      "version": "15.1.0"
    },
    // xdg-utils provides xdg-open, which opencode/other CLIs shell out to for
    // browser-based auth flows; without it, browser launches silently fail
    // even though $BROWSER is set. inotify-tools provides inotifywait, which
    // syncConfigOut.sh uses to push .claude.json out to the host the moment
    // it changes instead of polling. Installed as a feature rather than via
    // apt-get in postCreate.sh so both binaries exist before postCreateCommand
    // even starts: features install during container creation, ahead of
    // every lifecycle command, so a later postCreateCommand step failing
    // (npm/uv installs are the likelier culprits) can no longer prevent
    // syncConfigOut.sh's watcher from starting for lack of inotifywait — see
    // postCreate.sh for where that watcher gets launched and why timing here
    // matters.
    "ghcr.io/devcontainers-extra/features/apt-packages:1": {
      "packages": "xdg-utils,inotify-tools"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "2.96.0"
    },
    "ghcr.io/devcontainers-extra/features/claude-code:2": {
      "version": "2.1.204"
    },
    "ghcr.io/devcontainers-extra/features/opencode:1": {
      "version": "1.17.15"
    },
    "ghcr.io/devcontainers-extra/features/uv:1": {
      "version": "0.11.28"
    },
    // Node, pnpm, and nvm are exact pins here. CLI versions that should
    // move are updated by `make update-deps`, then
    // consumed as exact pins by feature options here and by
    // postCreate.sh's pnpm install step.
    "ghcr.io/devcontainers/features/node:2": {
      "version": "22.23.1",
      "pnpmVersion": "11.10.0",
      "nvmVersion": "0.40.5"
    },
    "ghcr.io/devcontainers/features/copilot-cli:1": {
      "version": "1.0.69"
    },
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "version": "29.6.1",
      "enableNonRootDocker": true,
      "moby": false
    },
    "ghcr.io/aqua/devcontainer-antigravity-cli/antigravity-cli:1": {}
  },
  "containerEnv": {
    "VIRTUAL_ENV": "/home/vscode/.venv",
    // The claude-code feature installs a pinned version, but the CLI itself
    // still self-updates in the background at container start regardless
    // (confirmed in practice via ~/.claude/.last-update-result.json showing a
    // "native" update firing seconds after postStart). That races with the
    // credential file at exactly the point rebuild-login-persistence broke,
    // so disable it the same way Copilot CLI's own feature-level auto-update
    // is disabled in postCreate.sh. `make update-deps` + a rebuild is the
    // explicit, intentional way to move this pin instead.
    "DISABLE_AUTOUPDATER": "1"
  },
  // Runs on the HOST, before the container is created, so the files below
  // exist by the time the mounts try to attach to them — see the script for
  // why that ordering matters.
  "initializeCommand": "bash .devcontainer/seedHostConfig.sh",
  // Every AI CLI's login and hand-set preferences need to survive a
  // container rebuild instead of re-provisioning from scratch each time.
  // This used to be one bind mount per file, read-write (every one of them
  // turned out to be rewritten by its tool at runtime — trust prompts,
  // first-run settings, `config set`-style commands — not just hand-edited,
  // so read-only broke each one with an opaque disk-write error the first
  // time that happened). That design had a worse problem than the
  // read-only one it fixed: a bind-mounted *single file* is bound to an
  // inode, not a path, and these tools save via write-temp-then-rename,
  // which replaces the inode at the mount point instead of updating it in
  // place. With the host's own copy of a CLI and a devcontainer's both able
  // to hold the same mounted file open at once, that's a live race, and
  // closing a container mid-write could leave a torn/truncated file on the
  // host — see this repo's history for the incident that surfaced it.
  //
  // Replacement: config-files.txt lists every one of these paths,
  // almost all of them whole directories. A *directory* bind mount doesn't
  // have the single-file problem above — a rename inside a mounted
  // directory only replaces that entry, never the mount point itself — so
  // each tool's directory is bind-mounted read-write straight from this
  // project's own backup onto its real container path (see "mounts"
  // below). seedHostConfig.sh (initializeCommand, host-side) seeds
  // that backup once, ever, from whatever the host has at that path the
  // very first time this project's container starts; after that, the live
  // mount is the only thing anyone reads or writes, forever — no copying,
  // no polling, and (deliberately) no folding container changes back onto
  // the host's own copy or any other project's. A prior version of this
  // did fold every change back onto the host on each rebuild — a
  // whole-file replace with no way to merge, so it was last-write-wins
  // against whatever the host or another project had changed since,
  // verified in practice to silently discard host edits, not just a
  // theoretical risk. See seedHostConfig.sh for the full story.
  //
  // .claude.json is the one exception: a bare file at $HOME root, not
  // inside its own directory, so it can't be bind-mounted the way the rest
  // are — same single-file rename problem as above. It still gets the old
  // file-by-file treatment (seeded once by seedHostConfig.sh, copied
  // in by postCreate.sh, polled back out by syncConfigOut.sh's
  // postStartCommand below), just scoped to this one file now instead of
  // every path.
  //
  // Project-local AI CLI override files are intentionally not used here.
  // Settings belong under $HOME in the container, where these mounts persist
  // them across rebuilds; workspace-local agent config is ignored.
  // Every source below lives under this same per-project root — keyed on
  // ${localWorkspaceFolder} (this project's absolute path), not its
  // basename, so two checkouts of differently-located repos that happen to
  // share a folder name can't collide on one sync directory. Kept in sync
  // manually with the equivalent computation in seedHostConfig.sh
  // ("$home/.devcontainer-agent-sync$PWD"), since one runs in a JSON string
  // and the other in a shell script.
  "mounts": [
    // Staging directory for .claude.json, the one path in
    // config-files.txt that isn't bind-mounted directly (see the
    // "initializeCommand" comment above for why).
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.devcontainer-agent-sync${localWorkspaceFolder},target=/home/vscode/.agent-sync,type=bind",
    // Everything else in config-files.txt: a live, read-write,
    // whole-directory bind mount straight from this project's own backup
    // onto the tool's real container path. No copying, no polling — see
    // the "initializeCommand" comment above.
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.devcontainer-agent-sync${localWorkspaceFolder}/.claude,target=/home/vscode/.claude,type=bind",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.devcontainer-agent-sync${localWorkspaceFolder}/.codex,target=/home/vscode/.codex,type=bind",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.devcontainer-agent-sync${localWorkspaceFolder}/.gemini,target=/home/vscode/.gemini,type=bind",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.devcontainer-agent-sync${localWorkspaceFolder}/.config/opencode,target=/home/vscode/.config/opencode,type=bind",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.devcontainer-agent-sync${localWorkspaceFolder}/.local/share/opencode,target=/home/vscode/.local/share/opencode,type=bind",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.devcontainer-agent-sync${localWorkspaceFolder}/.local/state/opencode,target=/home/vscode/.local/state/opencode,type=bind",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.devcontainer-agent-sync${localWorkspaceFolder}/.config/kilo,target=/home/vscode/.config/kilo,type=bind",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.devcontainer-agent-sync${localWorkspaceFolder}/.local/share/kilo,target=/home/vscode/.local/share/kilo,type=bind",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.devcontainer-agent-sync${localWorkspaceFolder}/.local/state/kilo,target=/home/vscode/.local/state/kilo,type=bind",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.devcontainer-agent-sync${localWorkspaceFolder}/.config/gh,target=/home/vscode/.config/gh,type=bind",
    // GitHub Copilot CLI: its login lives inside session-store.db (SQLite)
    // alongside everything else it stores, so auth can't be isolated to a
    // single file here either — same whole-directory treatment as the rest
    // above, now scoped per-project like everything else instead of one
    // mount shared globally across every project and the host.
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.devcontainer-agent-sync${localWorkspaceFolder}/.copilot,target=/home/vscode/.copilot,type=bind",
    // VS Code Local History lives under the remote server's user-data tree,
    // which is otherwise part of the container overlay and disappears when
    // the devcontainer is rebuilt. The mount target deliberately is NOT a
    // path under .vscode-server itself: Docker auto-creates a bind mount
    // target's whole ancestor chain as root at container-start, before the
    // container's own entrypoint/USER applies, so a target nested inside
    // .vscode-server forces that directory to exist as root before the
    // remote server (running as vscode) gets to it — and the server's own
    // "install myself" step (mkdir .vscode-server/bin) runs before
    // postCreateCommand, so no chown fix in postCreate.sh can run early
    // enough to save it (confirmed in practice: this is exactly the
    // permission-denied-on-mkdir failure that motivated this comment).
    // Mounting to this neutral path instead means .vscode-server is created
    // by the server itself, as vscode, completely unmounted-into and
    // unimpeded; postCreate.sh then symlinks History to here once that's
    // done.
    // "source=${localEnv:HOME}${localEnv:USERPROFILE}/.devcontainer-agent-sync${localWorkspaceFolder}/.vscode-server/data/User/History,target=/home/vscode/.local-history-sync,type=bind"
  ],
  // Put the venv's bin dir on PATH for every shell (equivalent to `source .venv/bin/activate`
  // but applies to non-interactive shells and VS Code's integrated terminal too). This must be
  // remoteEnv, not containerEnv: containerEnv is baked into the initial `docker run`, before a
  // container exists to query, so `${containerEnv:PATH}` can't resolve there and ends up literal
  // — which clobbers PATH entirely and breaks the container before it even starts.
  // pnpm's global bin dir rides along here for the same reason: postCreate.sh's
  // `pnpm install -g` (Codex, Kilocode) puts its shims in
  // ~/.local/share/pnpm/bin, which (unlike npm's old global prefix) isn't on
  // PATH anywhere by default.
  "remoteEnv": {
    "PATH": "/home/vscode/.venv/bin:/home/vscode/.local/share/pnpm/bin:/usr/local/share/nvm/current/bin:${containerEnv:PATH}"
  },
  // Marker only: this makes the otherwise-silent handoff from the host-side
  // initializeCommand to the in-container lifecycle visible in rebuild logs.
  "onCreateCommand": "date '+[devcontainer:%H:%M:%S] onCreate reached container lifecycle'",
  "postCreateCommand": "bash .devcontainer/postCreate.sh",
  // setsid+nohup'd and backgrounded so this returns immediately instead of
  // blocking startup on syncAgentConfigOut.sh's infinite inotifywait loop —
  // see that script and the "mounts" comment above for what it's syncing
  // and why. Plain `&` isn't enough here (confirmed in practice: the
  // watcher was found dead with no pidfile shortly after startup, stale
  // configs behind) — the Dev Containers CLI runs postStartCommand as its
  // own exec session, and whatever ends that session can take a bare
  // backgrounded child down with it. nohup alone was the first fix
  // (matches https://code.visualstudio.com/remote/advancedcontainers/start-processes)
  // but only blocks SIGHUP — it leaves the child in the same process group
  // as the exec session, so a group-wide kill (rather than a plain hangup)
  // still takes it down; confirmed live once more even with nohup in place
  // (watcher missing after a real rebuild, while a manual `docker exec`
  // replay of the identical command succeeded every time — the difference
  // being the real Dev Containers CLI's own session teardown). setsid
  // starts a brand new session and process group, so nothing that only
  // signals the old group can reach it. Runs on every start, not just
  // creation, since a plain restart of an existing container still needs
  // the watcher relaunched; the pidfile check inside the script itself is
  // what stops that from stacking a second watcher on top of one still
  // running.
  "postStartCommand": "setsid nohup bash .devcontainer/syncConfigOut.sh > /tmp/sync-config-out.log 2>&1 < /dev/null &",
  // Second, independent trigger for the same launch: postAttachCommand
  // fires whenever a client (VS Code, this CLI, anything) actually attaches
  // to the container, not just on container start — so if postStartCommand
  // ever gets missed or killed (the exact failure this is hardening
  // against), the next attach gets another chance. Safe to run redundantly:
  // syncConfigOut.sh's own pidfile check makes a second launch into a
  // no-op if the first one is still alive.
  "postAttachCommand": "setsid nohup bash .devcontainer/syncConfigOut.sh > /tmp/sync-config-out.log 2>&1 < /dev/null &",
  // Default waitFor is "updateContentCommand", so VS Code attaches and reads
  // python.defaultInterpreterPath before postCreateCommand has created the venv, causing
  // a spurious "no interpreter at path" warning on every fresh container. Block on it instead.
  "waitFor": "postCreateCommand",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance",
        "charliermarsh.ruff",
        // Matches [tool.mypy] in pyproject.toml, the strict-typing gate CI
        // enforces on custom_components/docker/scripts.
        "ms-python.mypy-type-checker",
        "tamasfe.even-better-toml",
        "redhat.vscode-yaml",
        // Workflow schema validation/autocomplete for .github/workflows/*.yaml.
        "github.vscode-github-actions",
        "ms-azuretools.vscode-docker",
        // Matches the hadolint-docker and shellcheck pre-commit hooks.
        "exiasr.hadolint",
        "timonwong.shellcheck"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/home/vscode/.venv/bin/python",
        // remoteEnv above already puts the venv's bin/ on PATH for every
        // shell, so the Python extension's default auto-activation just
        // adds a redundant `source .venv/bin/activate` line to every new
        // terminal (which itself runs in-container, hence belonging here).
        "python.terminal.activateEnvironment": false,
        // typeCheckingMode/extraPaths/etc. now live in [tool.pyright] in
        // pyproject.toml (which Pylance reads directly and takes precedence
        // over these settings) so there's one source of truth instead of two
        // partially-overlapping configs.
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.formatOnSave": true,
          "editor.codeActionsOnSave": {
            "source.fixAll.ruff": "explicit",
            "source.organizeImports.ruff": "explicit"
          }
        },
        "ruff.enable": true,
        // Default "file" scope passes the open file's path straight to
        // mypy, bypassing [tool.mypy]'s `exclude` (mypy only applies
        // `exclude` to directory recursion, not explicitly-passed paths) —
        // so it strict-checks tests/ even though CI never does. "workspace"
        // instead runs mypy with no explicit file args, so it picks up
        // `files`/`exclude` exactly like CI's `mypy .`.
        "mypy-type-checker.reportingScope": "workspace",
        // Default "openFilesOnly" only analyzes buffers you have open, same
        // gap as mypy's "file" scope had.
        "python.analysis.diagnosticMode": "workspace",
        // Pylance and mypy already report syntax errors (at workspace scope
        // now, so regardless of what's open). Ruff's own copy is pure
        // duplication with no autofix upside, unlike its lint rules above.
        "ruff.showSyntaxErrors": false,
        // Local History's data lives under .vscode-server's user-data tree
        // (see the "mounts" comment above) — it's persisted by the remote
        // server running in-container, not the local UI, so it belongs here
        // rather than in .vscode/settings.json.
        "workbench.localHistory.enabled": true
      }
    }
  }
}
