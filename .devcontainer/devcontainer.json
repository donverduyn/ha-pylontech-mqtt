// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/python
{
  "name": "Python 3",
  // Matches .github/workflows/tests.yaml's actions/setup-python version and
  // requirements_dev.lock.txt's --python-version target — a devcontainer on
  // a different Python/HA combination than CI is exactly the drift that let
  // this repo declare HA 2024.11 as its minimum while never testing it.
  "image": "mcr.microsoft.com/devcontainers/python:3-3.13-trixie",
  "features": {
    "ghcr.io/devcontainers-extra/features/ripgrep:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers-extra/features/claude-code:2": {},
    "ghcr.io/devcontainers-extra/features/opencode:1": {},
    "ghcr.io/devcontainers-extra/features/uv:1": {},
    // Pinned major version: the feature defaults to whatever "lts" resolves
    // to at build time, which drifts across major versions over a
    // container's lifetime. The npm-installed AI CLIs below (Codex,
    // Kilocode) are deliberately left unpinned instead — those want latest
    // by design, and floating is the whole point of an "agent" package.
    "ghcr.io/devcontainers/features/node:2": {
      "version": "22"
    },
    "ghcr.io/devcontainers/features/copilot-cli:1": {},
    "ghcr.io/aqua/devcontainer-antigravity-cli/antigravity-cli:1": {},
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "version": "latest",
      "enableNonRootDocker": "true",
      "moby": "false"
    }
  },
  "containerEnv": {
    "VIRTUAL_ENV": "/home/vscode/.venv"
  },
  // Runs on the HOST, before the container is created, so the files below
  // exist by the time the mounts try to attach to them — see the script for
  // why that ordering matters.
  "initializeCommand": "bash .devcontainer/seedHostAgentConfig.sh",
  // Every AI CLI's login and hand-set preferences need to survive a
  // container rebuild instead of re-provisioning from scratch each time.
  // This used to be one bind mount per file, read-write (every one of them
  // turned out to be rewritten by its tool at runtime — trust prompts,
  // first-run settings, `config set`-style commands — not just hand-edited,
  // so read-only broke each one with an opaque disk-write error the first
  // time that happened). That design had a worse problem than the
  // read-only one it fixed: a bind-mounted *single file* is bound to an
  // inode, not a path, and these tools save via write-temp-then-rename,
  // which replaces the inode at the mount point instead of updating it in
  // place. With the host's own copy of a CLI and a devcontainer's both able
  // to hold the same mounted file open at once, that's a live race, and
  // closing a container mid-write could leave a torn/truncated file on the
  // host — see this repo's history for the incident that surfaced it.
  //
  // Replacement: agent-config-files.txt lists every one of these paths,
  // almost all of them whole directories. A *directory* bind mount doesn't
  // have the single-file problem above — a rename inside a mounted
  // directory only replaces that entry, never the mount point itself — so
  // each tool's directory is bind-mounted read-write straight from this
  // project's own backup onto its real container path (see "mounts"
  // below). seedHostAgentConfig.sh (initializeCommand, host-side) seeds
  // that backup once, ever, from whatever the host has at that path the
  // very first time this project's container starts; after that, the live
  // mount is the only thing anyone reads or writes, forever — no copying,
  // no polling, and (deliberately) no folding container changes back onto
  // the host's own copy or any other project's. A prior version of this
  // did fold every change back onto the host on each rebuild — a
  // whole-file replace with no way to merge, so it was last-write-wins
  // against whatever the host or another project had changed since,
  // verified in practice to silently discard host edits, not just a
  // theoretical risk. See seedHostAgentConfig.sh for the full story.
  //
  // .claude.json is the one exception: a bare file at $HOME root, not
  // inside its own directory, so it can't be bind-mounted the way the rest
  // are — same single-file rename problem as above. It still gets the old
  // file-by-file treatment (seeded once by seedHostAgentConfig.sh, copied
  // in by postCreate.sh, polled back out by syncAgentConfigOut.sh's
  // postStartCommand below), just scoped to this one file now instead of
  // every path.
  //
  // Each tool also has its own native per-project override mechanism, which
  // needs no mount at all — it's just a file committed in this repo that
  // the tool itself merges on top of the synced global config:
  //   Claude Code   -> .claude/settings.json (or .claude/settings.local.json, gitignored)
  //   Codex         -> .codex/config.toml (walks up the tree; closest wins)
  //   OpenCode      -> opencode.json(c) in the repo root
  //   Kilocode CLI  -> .kilo/kilo.jsonc (wins) or kilo.jsonc in the repo root
  //   Copilot CLI   -> .github/mcp.json, .github/lsp.json, .github/hooks/
  //   Antigravity   -> .gemini/settings.json in the repo root (shares Gemini CLI's settings engine)
  //   GitHub CLI    -> no native project-level override; global-only
  // Every source below lives under this same per-project root — keyed on
  // ${localWorkspaceFolder} (this project's absolute path), not its
  // basename, so two checkouts of differently-located repos that happen to
  // share a folder name can't collide on one sync directory. Kept in sync
  // manually with the equivalent computation in seedHostAgentConfig.sh
  // ("$home/.devcontainer-agent-sync$PWD"), since one runs in a JSON string
  // and the other in a shell script.
  "mounts": [
    // Staging directory for .claude.json, the one path in
    // agent-config-files.txt that isn't bind-mounted directly (see the
    // "initializeCommand" comment above for why).
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.devcontainer-agent-sync${localWorkspaceFolder},target=/home/vscode/.agent-sync,type=bind",
    // Everything else in agent-config-files.txt: a live, read-write,
    // whole-directory bind mount straight from this project's own backup
    // onto the tool's real container path. No copying, no polling — see
    // the "initializeCommand" comment above.
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.devcontainer-agent-sync${localWorkspaceFolder}/.claude,target=/home/vscode/.claude,type=bind",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.devcontainer-agent-sync${localWorkspaceFolder}/.codex,target=/home/vscode/.codex,type=bind",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.devcontainer-agent-sync${localWorkspaceFolder}/.gemini,target=/home/vscode/.gemini,type=bind",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.devcontainer-agent-sync${localWorkspaceFolder}/.config/opencode,target=/home/vscode/.config/opencode,type=bind",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.devcontainer-agent-sync${localWorkspaceFolder}/.local/share/opencode,target=/home/vscode/.local/share/opencode,type=bind",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.devcontainer-agent-sync${localWorkspaceFolder}/.config/kilo,target=/home/vscode/.config/kilo,type=bind",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.devcontainer-agent-sync${localWorkspaceFolder}/.config/gh,target=/home/vscode/.config/gh,type=bind",
    // GitHub Copilot CLI: its login lives inside session-store.db (SQLite)
    // alongside everything else it stores, so auth can't be isolated to a
    // single file here either — same whole-directory treatment as the rest
    // above, now scoped per-project like everything else instead of one
    // mount shared globally across every project and the host.
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.devcontainer-agent-sync${localWorkspaceFolder}/.copilot,target=/home/vscode/.copilot,type=bind"
  ],
  // Put the venv's bin dir on PATH for every shell (equivalent to `source .venv/bin/activate`
  // but applies to non-interactive shells and VS Code's integrated terminal too). This must be
  // remoteEnv, not containerEnv: containerEnv is baked into the initial `docker run`, before a
  // container exists to query, so `${containerEnv:PATH}` can't resolve there and ends up literal
  // — which clobbers PATH entirely and breaks the container before it even starts.
  "remoteEnv": {
    "PATH": "/home/vscode/.venv/bin:/usr/local/share/nvm/current/bin:${containerEnv:PATH}"
  },
  "postCreateCommand": "bash .devcontainer/postCreate.sh",
  // nohup'd and backgrounded so this returns immediately instead of blocking
  // startup on syncAgentConfigOut.sh's infinite inotifywait loop — see that
  // script and the "mounts" comment above for what it's syncing and why.
  // Plain `&` isn't enough here (confirmed in practice: the watcher was
  // found dead with no pidfile shortly after startup, stale configs behind)
  // — the Dev Containers CLI runs postStartCommand as its own exec session,
  // and whatever ends that session can take a bare backgrounded child down
  // with it. nohup detaches the process from that session so it survives
  // past the command "finishing"; see
  // https://code.visualstudio.com/remote/advancedcontainers/start-processes
  // for the same guidance. Runs on every start, not just creation, since a
  // plain restart of an existing container still needs the watcher
  // relaunched; the pidfile check inside the script itself is what stops
  // that from stacking a second watcher on top of one still running.
  "postStartCommand": "nohup bash .devcontainer/syncAgentConfigOut.sh > /tmp/sync-agent-config-out.log 2>&1 &",
  // Default waitFor is "updateContentCommand", so VS Code attaches and reads
  // python.defaultInterpreterPath before postCreateCommand has created the venv, causing
  // a spurious "no interpreter at path" warning on every fresh container. Block on it instead.
  "waitFor": "postCreateCommand",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance",
        "charliermarsh.ruff",
        // Matches [tool.mypy] in pyproject.toml, the strict-typing gate CI
        // enforces on custom_components/docker/scripts.
        "ms-python.mypy-type-checker",
        "tamasfe.even-better-toml",
        "redhat.vscode-yaml",
        // Workflow schema validation/autocomplete for .github/workflows/*.yaml.
        "github.vscode-github-actions",
        "ms-azuretools.vscode-docker",
        // Matches the hadolint-docker and shellcheck pre-commit hooks.
        "exiasr.hadolint",
        "timonwong.shellcheck"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/home/vscode/.venv/bin/python",
        // typeCheckingMode/extraPaths/etc. now live in [tool.pyright] in
        // pyproject.toml (which Pylance reads directly and takes precedence
        // over these settings) so there's one source of truth instead of two
        // partially-overlapping configs.
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.formatOnSave": true,
          "editor.codeActionsOnSave": {
            "source.fixAll.ruff": "explicit",
            "source.organizeImports.ruff": "explicit"
          }
        },
        "ruff.enable": true
      }
    }
  }
}